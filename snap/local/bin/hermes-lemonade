#!/bin/sh
# hermes-lemonade — interactive Lemonade model picker for Hermes Agent.
#
# Probes the local lemonade-server, presents a menu to choose one of its loaded
# models, and configures Hermes to use it via `hermes config set`, then
# restarts the gateway so the change takes effect.
#
# Run as:  hermes-agent.lemonade

export PATH="$SNAP/bin:$PATH"
export PYTHONPATH="$SNAP/lib/python3.12/site-packages${PYTHONPATH:+:$PYTHONPATH}"
CURL="$SNAP/usr/bin/curl"

CLI="hermes-agent"
LEMONADE_HOST="${CLAW_LEMONADE_HOST:-127.0.0.1}"
LEMONADE_PORT="${CLAW_LEMONADE_PORT:-13305}"
# Hermes's base_url includes the API path prefix.  Lemonade's OpenAI-compatible
# endpoint lives at /api/v1, not the conventional /v1.
LEMONADE_BASE_URL="http://${LEMONADE_HOST}:${LEMONADE_PORT}/api/v1"

SERVICE_NAME="hermes-agent"

log() { printf '%s: %s\n' "$CLI" "$1"; }
err() { printf '%s: %s\n' "$CLI" "$1" >&2; }

probe_models() {
  "$CURL" -sf --connect-timeout 3 --max-time 5 "${1}/models" 2>/dev/null \
    | grep -o '"id"[[:space:]]*:[[:space:]]*"[^"]*"' \
    | sed 's/.*"id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/'
}

is_non_chat() {
  lower=$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')
  case "$lower" in
    *flux*|*sdxl*|*stable?diff*) return 0 ;;
    *kokoro*|*whisper*|*tts*|*speech*) return 0 ;;
    *embed*|*retriev*|*rerank*) return 0 ;;
  esac
  return 1
}

configure() {
  model_id="$1"
  "$SNAP/bin/hermes" config set model.provider custom >/dev/null 2>&1 || return 1
  "$SNAP/bin/hermes" config set model.base_url "$LEMONADE_BASE_URL" >/dev/null 2>&1 || return 1
  "$SNAP/bin/hermes" config set model.default "$model_id" >/dev/null 2>&1 || return 1
  "$SNAP/bin/hermes" config set model.api_key lemonade >/dev/null 2>&1 || true
}

ALL_MODELS=$(probe_models "http://${LEMONADE_HOST}:${LEMONADE_PORT}/api/v1")
if [ -z "$ALL_MODELS" ]; then
  err "lemonade-server not detected at ${LEMONADE_HOST}:${LEMONADE_PORT}"
  err "start lemonade-server, then run '${CLI}.lemonade' again"
  exit 1
fi

MODELS=""
for m in $ALL_MODELS; do
  is_non_chat "$m" && continue
  MODELS="${MODELS}${m}
"
done
MODELS=$(printf '%s' "$MODELS" | sed '/^$/d')
COUNT=$(printf '%s\n' "$MODELS" | grep -c .)
if [ "$COUNT" -eq 0 ]; then
  MODELS=$(printf '%s\n' "$ALL_MODELS" | sed '/^$/d')
  COUNT=$(printf '%s\n' "$MODELS" | grep -c .)
fi

if [ ! -t 0 ] || [ ! -t 1 ]; then
  SELECTED=$(printf '%s\n' "$MODELS" | head -1)
  if configure "$SELECTED"; then
    log "configured lemonade/${SELECTED} (non-interactive)"
    systemctl --user restart "$SERVICE_NAME" >/dev/null 2>&1 || true
    exit 0
  fi
  err "failed to configure ${SELECTED}"
  exit 1
fi

printf '\nHermes Agent detected Lemonade at %s.\n' "$LEMONADE_BASE_URL"
printf 'Choose a model to use as the primary provider:\n\n'

i=1
printf '%s\n' "$MODELS" | while IFS= read -r m; do
  [ -z "$m" ] && continue
  printf '  %d. %s\n' "$i" "$m"
  i=$((i + 1))
done
printf '\n'

while true; do
  printf 'Model number [1]: '
  read -r choice
  [ -z "$choice" ] && choice=1
  case "$choice" in
    ''|*[!0-9]*) continue ;;
  esac
  if [ "$choice" -ge 1 ] && [ "$choice" -le "$COUNT" ]; then
    break
  fi
done

SELECTED=$(printf '%s\n' "$MODELS" | sed -n "${choice}p")

if configure "$SELECTED"; then
  log "primary model -> lemonade/${SELECTED}  (${LEMONADE_BASE_URL})"
  if systemctl --user restart "$SERVICE_NAME" >/dev/null 2>&1; then
    log "restarted the gateway service"
  else
    log "run 'systemctl --user restart ${SERVICE_NAME}' to apply"
  fi
else
  err "failed to configure ${SELECTED}"
  exit 1
fi
