#!/bin/sh
# hermes-lemonade — interactive Lemonade model picker for Hermes Agent.
#
# Probes the local lemonade-server, presents a menu to choose one of its loaded
# models, and configures Hermes to use it via `hermes config set`, then
# restarts the gateway so the change takes effect.
#
# Run as:  hermes-agent.lemonade [--auto]
#
# --auto: non-interactive; picks the first available chat model and configures
#         it without user interaction.  Also installs the systemd user service
#         unit if it has not been set up yet (safe to run on first install).

export PATH="$SNAP/bin:$PATH"
export PYTHONPATH="$SNAP/lib/python3.12/site-packages${PYTHONPATH:+:$PYTHONPATH}"
CURL="$SNAP/usr/bin/curl"

CLI="hermes-agent"
LEMONADE_HOST="${CLAW_LEMONADE_HOST:-127.0.0.1}"
LEMONADE_PORT="${CLAW_LEMONADE_PORT:-13305}"
# Hermes's base_url includes the API path prefix.  Lemonade's OpenAI-compatible
# endpoint lives at /api/v1, not the conventional /v1.
LEMONADE_BASE_URL="http://${LEMONADE_HOST}:${LEMONADE_PORT}/api/v1"

SERVICE_NAME="hermes-agent"

log() { printf '%s: %s\n' "$CLI" "$1"; }
err() { printf '%s: %s\n' "$CLI" "$1" >&2; }

# Parse arguments.
AUTO=0
MODEL=""
_prev=""
for arg in "$@"; do
  [ "$_prev" = "--model" ] && { MODEL="$arg"; _prev=""; continue; }
  case "$arg" in
    --auto) AUTO=1 ;;
    --model=*) MODEL="${arg#--model=}" ;;
    --model)   _prev="--model" ;;
    *) err "unknown argument: $arg"; exit 1 ;;
  esac
  _prev="$arg"
done

# Install (or refresh) the systemd user service unit.  Called by --auto so
# the service is available even when the main launcher has not been run yet.
_install_service_unit() {
  local unit_src="$SNAP/share/systemd/user/${SERVICE_NAME}.service"
  local unit_dir="$HOME/.config/systemd/user"
  local unit_dst="$unit_dir/${SERVICE_NAME}.service"
  [ -f "$unit_src" ] || return 0
  mkdir -p "$unit_dir"
  if [ ! -f "$unit_dst" ] || ! cmp -s "$unit_src" "$unit_dst"; then
    cp "$unit_src" "$unit_dst"
    systemctl --user daemon-reload 2>/dev/null || true
  fi
  if ! systemctl --user is-enabled "$SERVICE_NAME" >/dev/null 2>&1; then
    systemctl --user enable --now "$SERVICE_NAME" 2>/dev/null || true
  fi
}

score_model() {
  lower=$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')
  case "$lower" in
    *flux*|*sdxl*|*stable?diff*) printf '%s\n' -30; return ;;
    *kokoro*|*whisper*|*tts*|*speech*) printf '%s\n' -20; return ;;
    *embed*|*retriev*|*rerank*) printf '%s\n' -20; return ;;
  esac
  score=0
  case "$lower" in *flm*)               score=$((score + 20)) ;; esac
  case "$lower" in *gguf*)              score=$((score + 10)) ;; esac
  case "$lower" in *instruct*|*-it-*|*chat*) score=$((score + 5)) ;; esac
  printf '%s\n' "$score"
}

pick_best() {
  best_id=""; best_score=-999
  while IFS= read -r id; do
    [ -z "$id" ] && continue
    s=$(score_model "$id")
    if [ "$s" -ge 0 ] && [ "$s" -gt "$best_score" ]; then
      best_score="$s"; best_id="$id"
    fi
  done
  [ -n "$best_id" ] && printf '%s\n' "$best_id"
}

probe_models() {
  "$CURL" -sf --connect-timeout 3 --max-time 5 "${1}/models" 2>/dev/null \
    | grep -o '"id"[[:space:]]*:[[:space:]]*"[^"]*"' \
    | sed 's/.*"id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/'
}

is_non_chat() {
  lower=$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')
  case "$lower" in
    *flux*|*sdxl*|*stable?diff*) return 0 ;;
    *kokoro*|*whisper*|*tts*|*speech*) return 0 ;;
    *embed*|*retriev*|*rerank*) return 0 ;;
  esac
  return 1
}

configure() {
  # Use the native 'lemonade' provider type so hermes auto-selects the model
  # at runtime from the lemonade server's available models.  This also makes
  # the provider appear correctly as "Lemonade" in the web dashboard.
  "$SNAP/bin/hermes" config set model.provider lemonade >/dev/null 2>&1 || return 1
  "$SNAP/bin/hermes" config set model.base_url "$LEMONADE_BASE_URL" >/dev/null 2>&1 || return 1
  "$SNAP/bin/hermes" config set model.api_key lemonade >/dev/null 2>&1 || true
}

ALL_MODELS=$(probe_models "http://${LEMONADE_HOST}:${LEMONADE_PORT}/api/v1")
if [ -z "$ALL_MODELS" ]; then
  err "lemonade-server not detected at ${LEMONADE_HOST}:${LEMONADE_PORT}"
  err "start lemonade-server, then run '${CLI}.lemonade' again"
  exit 1
fi

MODELS=""
for m in $ALL_MODELS; do
  is_non_chat "$m" && continue
  MODELS="${MODELS}${m}
"
done
MODELS=$(printf '%s' "$MODELS" | sed '/^$/d')
COUNT=$(printf '%s\n' "$MODELS" | grep -c .)
if [ "$COUNT" -eq 0 ]; then
  MODELS=$(printf '%s\n' "$ALL_MODELS" | sed '/^$/d')
  COUNT=$(printf '%s\n' "$MODELS" | grep -c .)
fi

# Non-interactive: --auto flag or no TTY.
if [ "$AUTO" -eq 1 ] || [ ! -t 0 ] || [ ! -t 1 ]; then
  if [ "$AUTO" -eq 1 ]; then
    _install_service_unit
    if configure; then
      log "auto-configured lemonade provider (model selected at runtime)"
      systemctl --user restart "$SERVICE_NAME" >/dev/null 2>&1 || true
      exit 0
    fi
    err "failed to configure lemonade provider"
    exit 1
  else
    if configure; then
      log "configured lemonade provider (non-interactive)"
      systemctl --user restart "$SERVICE_NAME" >/dev/null 2>&1 || true
      exit 0
    fi
    err "failed to configure lemonade provider"
    exit 1
  fi
fi

printf '\nHermes Agent detected Lemonade at %s.\n' "$LEMONADE_BASE_URL"
printf 'Configuring Lemonade as the model provider (model selected at runtime)...\n\n'

if configure; then
  log "provider -> lemonade  (${LEMONADE_BASE_URL})"
  if systemctl --user restart "$SERVICE_NAME" >/dev/null 2>&1; then
    log "restarted the gateway service"
  else
    log "run 'systemctl --user restart ${SERVICE_NAME}' to apply"
  fi
else
  err "failed to configure lemonade provider"
  exit 1
fi
