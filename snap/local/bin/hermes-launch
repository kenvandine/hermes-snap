#!/bin/sh
# hermes-launch — wrapper that puts bundled Node.js on PATH and ensures
# Playwright can find its baked-in Chromium.

export PATH="$SNAP/bin:$PATH"
export PLAYWRIGHT_BROWSERS_PATH="$SNAP/usr/share/ms-playwright"
# The bundled venv's pyvenv.cfg 'home' is repointed into the snap so Python
# finds the bundled stdlib; that makes Python treat it as a non-venv install,
# so the venv's site-packages must be added explicitly here.
export PYTHONPATH="$SNAP/lib/python3.12/site-packages${PYTHONPATH:+:$PYTHONPATH}"

mkdir -p "$HOME/.hermes"

# Install/refresh and enable the gateway service.  Re-copy the unit whenever the
# bundled copy changes (e.g. after a snap refresh) so updates actually land,
# rather than only installing once on the very first run.
SYSTEMD_USER_DIR="$HOME/.config/systemd/user"
SERVICE_NAME="hermes-agent"
UNIT_PATH="$SYSTEMD_USER_DIR/${SERVICE_NAME}.service"
mkdir -p "$SYSTEMD_USER_DIR"
if [ ! -f "$UNIT_PATH" ] || ! cmp -s "$SNAP/share/systemd/user/${SERVICE_NAME}.service" "$UNIT_PATH"; then
  cp "$SNAP/share/systemd/user/${SERVICE_NAME}.service" "$UNIT_PATH"
  systemctl --user daemon-reload 2>/dev/null || true
fi
if ! systemctl --user is-enabled "$SERVICE_NAME" >/dev/null 2>&1; then
  systemctl --user enable --now "$SERVICE_NAME" 2>/dev/null || true
fi

exec "$SNAP/bin/hermes" "$@"
